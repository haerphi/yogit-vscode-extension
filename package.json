{
    "name": "haerphi-yogit",
    "displayName": "YoGit",
    "description": "An extension to help you using Git and have a clear visualisation of what you're doing!",
    "version": "1.0.0",
    "publisher": "haerphi",
    "license": "MIT",
    "packageManager": "pnpm@11.7.0",
    "repository": {
        "url": "https://github.com/haerphi/yogit-vscode-extension"
    },
    "engines": {
        "vscode": "^1.125.0"
    },
    "categories": [
        "SCM Providers",
        "Other"
    ],
    "keywords": [
        "git",
        "scm",
        "branch",
        "rebase",
        "stash",
        "merge",
        "commit",
        "push",
        "pull",
        "version control"
    ],
    "activationEvents": [
        "onView:commit",
        "onView:branches",
        "onView:remotes",
        "onView:changes",
        "onView:stash"
    ],
    "main": "./out/extension.js",
    "extensionKind": [
        "workspace"
    ],
    "l10n": "./l10n",
    "contributes": {
        "commands": [
            {
                "command": "haerphi-yogit.create-branch",
                "title": "%cmd.create-branch.title%",
                "icon": "$(add)"
            },
            {
                "command": "haerphi-yogit.create-branch-from",
                "title": "%cmd.create-branch-from.title%"
            },
            {
                "command": "haerphi-yogit.switch",
                "title": "%cmd.switch.title%",
                "icon": "$(arrow-right)"
            },
            {
                "command": "haerphi-yogit.switch-force",
                "title": "%cmd.switch-force.title%"
            },
            {
                "command": "haerphi-yogit.copy-branch-name",
                "title": "%cmd.copy-branch-name.title%"
            },
            {
                "command": "haerphi-yogit.open-file",
                "title": "%cmd.open-file.title%"
            },
            {
                "command": "haerphi-yogit.copy-file-name",
                "title": "%cmd.copy-file-name.title%"
            },
            {
                "command": "haerphi-yogit.rename-branch",
                "title": "%cmd.rename-branch.title%"
            },
            {
                "command": "haerphi-yogit.delete-branch",
                "title": "%cmd.delete-branch.title%",
                "icon": "$(trash)"
            },
            {
                "command": "haerphi-yogit.delete-branch-remote",
                "title": "%cmd.delete-branch-remote.title%",
                "icon": "$(trash)"
            },
            {
                "command": "haerphi-yogit.stage-file",
                "title": "%cmd.stage-file.title%",
                "icon": "$(add)"
            },
            {
                "command": "haerphi-yogit.unstage-file",
                "title": "%cmd.unstage-file.title%",
                "icon": "$(remove)"
            },
            {
                "command": "haerphi-yogit.stage-all",
                "title": "%cmd.stage-all.title%",
                "icon": "$(add)"
            },
            {
                "command": "haerphi-yogit.unstage-all",
                "title": "%cmd.unstage-all.title%",
                "icon": "$(remove)"
            },
            {
                "command": "haerphi-yogit.stage-hunks",
                "title": "%cmd.stage-hunks.title%",
                "icon": "$(list-selection)"
            },
            {
                "command": "haerphi-yogit.unstage-hunks",
                "title": "%cmd.unstage-hunks.title%",
                "icon": "$(list-selection)"
            },
            {
                "command": "haerphi-yogit.stash",
                "title": "%cmd.stash.title%",
                "icon": "$(archive)"
            },
            {
                "command": "haerphi-yogit.show-log",
                "title": "%cmd.show-log.title%",
                "icon": "$(history)"
            },
            {
                "command": "haerphi-yogit.fetch",
                "title": "%cmd.fetch.title%",
                "icon": "$(sync)"
            },
            {
                "command": "haerphi-yogit.pull",
                "title": "%cmd.pull.title%",
                "icon": "$(arrow-down)"
            },
            {
                "command": "haerphi-yogit.push",
                "title": "%cmd.push.title%",
                "icon": "$(arrow-up)"
            },
            {
                "command": "haerphi-yogit.stash-show",
                "title": "%cmd.stash-show.title%"
            },
            {
                "command": "haerphi-yogit.stash-pop",
                "title": "%cmd.stash-pop.title%",
                "icon": "$(run)"
            },
            {
                "command": "haerphi-yogit.stash-apply",
                "title": "%cmd.stash-apply.title%"
            },
            {
                "command": "haerphi-yogit.stash-drop",
                "title": "%cmd.stash-drop.title%",
                "icon": "$(trash)"
            },
            {
                "command": "haerphi-yogit.merge",
                "title": "%cmd.merge.title%",
                "icon": "$(git-merge)"
            },
            {
                "command": "haerphi-yogit.rebase-onto",
                "title": "%cmd.rebase-onto.title%",
                "icon": "$(git-commit)"
            },
            {
                "command": "haerphi-yogit.rebase-interactive",
                "title": "%cmd.rebase-interactive.title%",
                "icon": "$(git-commit)"
            },
            {
                "command": "haerphi-yogit.resolve-conflict",
                "title": "%cmd.resolve-conflict.title%",
                "icon": "$(diff)"
            },
            {
                "command": "haerphi-yogit.abort-rebase",
                "title": "%cmd.abort-rebase.title%",
                "icon": "$(discard)"
            },
            {
                "command": "haerphi-yogit.continue-rebase",
                "title": "%cmd.continue-rebase.title%",
                "icon": "$(play)"
            },
            {
                "command": "haerphi-yogit.discard-file",
                "title": "%cmd.discard-file.title%",
                "icon": "$(discard)"
            },
            {
                "command": "haerphi-yogit.discard-all",
                "title": "%cmd.discard-all.title%",
                "icon": "$(discard)"
            },
            {
                "command": "haerphi-yogit.init-repo",
                "title": "%cmd.init-repo.title%",
                "icon": "$(repo-create)"
            },
            {
                "command": "haerphi-yogit.clone-repo",
                "title": "%cmd.clone-repo.title%",
                "icon": "$(repo-clone)"
            },
            {
                "command": "haerphi-yogit.link-repo",
                "title": "%cmd.link-repo.title%",
                "icon": "$(link)"
            },
            {
                "command": "haerphi-yogit.add-remote",
                "title": "%cmd.add-remote.title%",
                "icon": "$(add)"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "haerphi-yogit.init-repo",
                    "when": "haerphi-yogit.noRepo"
                },
                {
                    "command": "haerphi-yogit.clone-repo",
                    "when": "haerphi-yogit.noRepo"
                },
                {
                    "command": "haerphi-yogit.link-repo",
                    "when": "haerphi-yogit.noRepo"
                }
            ],
            "view/title": [
                {
                    "command": "haerphi-yogit.show-log",
                    "when": "view == branches",
                    "group": "navigation@1"
                },
                {
                    "command": "haerphi-yogit.fetch",
                    "when": "view == branches",
                    "group": "navigation@2"
                },
                {
                    "command": "haerphi-yogit.pull",
                    "when": "view == branches",
                    "group": "navigation@3"
                },
                {
                    "command": "haerphi-yogit.push",
                    "when": "view == branches",
                    "group": "navigation@4"
                },
                {
                    "command": "haerphi-yogit.create-branch",
                    "when": "view == branches",
                    "group": "navigation@5"
                },
                {
                    "command": "haerphi-yogit.fetch",
                    "when": "view == remotes",
                    "group": "navigation@1"
                },
                {
                    "command": "haerphi-yogit.add-remote",
                    "when": "view == remotes",
                    "group": "navigation@2"
                },
                {
                    "command": "haerphi-yogit.stash",
                    "when": "view == changes",
                    "group": "navigation"
                },
                {
                    "command": "haerphi-yogit.abort-rebase",
                    "when": "view == changes && haerphi-yogit.rebaseInProgress",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "haerphi-yogit.switch",
                    "when": "(view == branches || view == remotes) && viewItem =~ /^branch/",
                    "group": "inline"
                },
                {
                    "command": "haerphi-yogit.switch",
                    "when": "(view == branches || view == remotes) && viewItem =~ /^branch/",
                    "group": "1_switch@1"
                },
                {
                    "command": "haerphi-yogit.switch-force",
                    "when": "(view == branches || view == remotes) && viewItem =~ /^branch/",
                    "group": "1_switch@2"
                },
                {
                    "command": "haerphi-yogit.create-branch-from",
                    "when": "(view == branches || view == remotes) && viewItem =~ /^branch/",
                    "group": "2_branch@1"
                },
                {
                    "command": "haerphi-yogit.rename-branch",
                    "when": "view == branches && viewItem =~ /^branch-local/",
                    "group": "2_branch@2"
                },
                {
                    "command": "haerphi-yogit.merge",
                    "when": "(view == branches || view == remotes) && viewItem =~ /^branch/ && viewItem != branch-local-current",
                    "group": "3_rebase@1"
                },
                {
                    "command": "haerphi-yogit.rebase-onto",
                    "when": "(view == branches || view == remotes) && viewItem =~ /^branch/ && viewItem != branch-local-current",
                    "group": "3_rebase@2"
                },
                {
                    "command": "haerphi-yogit.rebase-interactive",
                    "when": "(view == branches || view == remotes) && viewItem =~ /^branch/ && viewItem != branch-local-current",
                    "group": "3_rebase@3"
                },
                {
                    "command": "haerphi-yogit.pull",
                    "when": "view == branches && viewItem == branch-local-current",
                    "group": "inline"
                },
                {
                    "command": "haerphi-yogit.push",
                    "when": "view == branches && viewItem == branch-local-current",
                    "group": "inline"
                },
                {
                    "command": "haerphi-yogit.pull",
                    "when": "view == branches && viewItem == branch-local-current",
                    "group": "1_sync@1"
                },
                {
                    "command": "haerphi-yogit.push",
                    "when": "view == branches && viewItem == branch-local-current",
                    "group": "1_sync@2"
                },
                {
                    "command": "haerphi-yogit.delete-branch",
                    "when": "view == branches && viewItem =~ /^branch-local/",
                    "group": "4_delete"
                },
                {
                    "command": "haerphi-yogit.delete-branch-remote",
                    "when": "view == remotes && viewItem == branch-remote",
                    "group": "4_delete"
                },
                {
                    "command": "haerphi-yogit.copy-branch-name",
                    "when": "(view == branches || view == remotes) && viewItem =~ /^branch/",
                    "group": "5_copy"
                },
                {
                    "command": "haerphi-yogit.stage-file",
                    "when": "view == changes && viewItem == change-unstaged",
                    "group": "inline"
                },
                {
                    "command": "haerphi-yogit.stage-hunks",
                    "when": "view == changes && viewItem == change-unstaged",
                    "group": "inline"
                },
                {
                    "command": "haerphi-yogit.stage-file",
                    "when": "view == changes && viewItem == change-unstaged",
                    "group": "1_stage@1"
                },
                {
                    "command": "haerphi-yogit.stage-hunks",
                    "when": "view == changes && viewItem == change-unstaged",
                    "group": "1_stage@2"
                },
                {
                    "command": "haerphi-yogit.unstage-file",
                    "when": "view == changes && viewItem == change-staged",
                    "group": "inline"
                },
                {
                    "command": "haerphi-yogit.unstage-hunks",
                    "when": "view == changes && viewItem == change-staged",
                    "group": "inline"
                },
                {
                    "command": "haerphi-yogit.unstage-file",
                    "when": "view == changes && viewItem == change-staged",
                    "group": "1_stage@1"
                },
                {
                    "command": "haerphi-yogit.unstage-hunks",
                    "when": "view == changes && viewItem == change-staged",
                    "group": "1_stage@2"
                },
                {
                    "command": "haerphi-yogit.resolve-conflict",
                    "when": "view == changes && viewItem == change-conflict",
                    "group": "inline"
                },
                {
                    "command": "haerphi-yogit.resolve-conflict",
                    "when": "view == changes && viewItem == change-conflict",
                    "group": "1_resolve"
                },
                {
                    "command": "haerphi-yogit.stage-all",
                    "when": "view == changes && viewItem == group-unstaged",
                    "group": "inline"
                },
                {
                    "command": "haerphi-yogit.discard-all",
                    "when": "view == changes && viewItem == group-unstaged",
                    "group": "inline"
                },
                {
                    "command": "haerphi-yogit.discard-all",
                    "when": "view == changes && viewItem == group-unstaged",
                    "group": "1_discard"
                },
                {
                    "command": "haerphi-yogit.unstage-all",
                    "when": "view == changes && viewItem == group-staged",
                    "group": "inline"
                },
                {
                    "command": "haerphi-yogit.discard-file",
                    "when": "view == changes && viewItem == change-unstaged",
                    "group": "2_discard"
                },
                {
                    "command": "haerphi-yogit.open-file",
                    "when": "view == changes && viewItem =~ /^change/",
                    "group": "3_file@1"
                },
                {
                    "command": "haerphi-yogit.copy-file-name",
                    "when": "view == changes && viewItem =~ /^change/",
                    "group": "3_file@2"
                },
                {
                    "command": "haerphi-yogit.stash-pop",
                    "when": "view == stash && viewItem == stash-entry",
                    "group": "inline"
                },
                {
                    "command": "haerphi-yogit.stash-drop",
                    "when": "view == stash && viewItem == stash-entry",
                    "group": "inline"
                },
                {
                    "command": "haerphi-yogit.stash-pop",
                    "when": "view == stash && viewItem == stash-entry",
                    "group": "1_apply@1"
                },
                {
                    "command": "haerphi-yogit.stash-apply",
                    "when": "view == stash && viewItem == stash-entry",
                    "group": "1_apply@2"
                },
                {
                    "command": "haerphi-yogit.stash-drop",
                    "when": "view == stash && viewItem == stash-entry",
                    "group": "2_delete"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "yogit-side-panel",
                    "title": "YoGit",
                    "icon": "media/yogit.png"
                }
            ]
        },
        "views": {
            "yogit-side-panel": [
                {
                    "id": "commit",
                    "name": "%view.commit.name%",
                    "type": "webview"
                },
                {
                    "id": "changes",
                    "name": "%view.changes.name%"
                },
                {
                    "id": "stash",
                    "name": "%view.stash.name%"
                },
                {
                    "id": "branches",
                    "name": "%view.branches.name%"
                },
                {
                    "id": "remotes",
                    "name": "%view.remotes.name%"
                }
            ]
        },
        "viewsWelcome": [
            {
                "view": "branches",
                "contents": "%welcome.branches.noRepo%",
                "when": "haerphi-yogit.noRepo"
            },
            {
                "view": "remotes",
                "contents": "%welcome.remotes.default%",
                "when": "!haerphi-yogit.noRepo"
            },
            {
                "view": "remotes",
                "contents": "%welcome.remotes.noRepo%",
                "when": "haerphi-yogit.noRepo"
            },
            {
                "view": "changes",
                "contents": "%welcome.changes.default%",
                "when": "!haerphi-yogit.noRepo"
            },
            {
                "view": "changes",
                "contents": "%welcome.changes.noRepo%",
                "when": "haerphi-yogit.noRepo"
            },
            {
                "view": "stash",
                "contents": "%welcome.stash.default%",
                "when": "!haerphi-yogit.noRepo"
            },
            {
                "view": "stash",
                "contents": "%welcome.stash.noRepo%",
                "when": "haerphi-yogit.noRepo"
            }
        ],
        "configuration": {
            "title": "YoGit",
            "properties": {
                "haerphi-yogit.language": {
                    "type": "string",
                    "enum": [
                        "auto",
                        "en",
                        "fr"
                    ],
                    "enumDescriptions": [
                        "%config.language.enum.auto%",
                        "%config.language.enum.en%",
                        "%config.language.enum.fr%"
                    ],
                    "default": "auto",
                    "description": "%config.language.description%"
                },
                "haerphi-yogit.rebase.defaultOrder": {
                    "type": "string",
                    "enum": [
                        "oldest-first",
                        "newest-first"
                    ],
                    "enumDescriptions": [
                        "%config.rebase.defaultOrder.enum.oldestFirst%",
                        "%config.rebase.defaultOrder.enum.newestFirst%"
                    ],
                    "default": "oldest-first",
                    "description": "%config.rebase.defaultOrder.description%"
                }
            }
        }
    },
    "extensionDependencies": [
        "vscode.git"
    ],
    "scripts": {
        "vscode:prepublish": "pnpm run compile",
        "compile": "tsc -p ./ && esbuild src/webview/modal/index.ts --bundle --outfile=out/webview/modal.js --format=iife --platform=browser --tsconfig=tsconfig.webview.json && esbuild src/webview/diff/index.ts --bundle --outfile=out/webview/diff.js --format=iife --platform=browser --tsconfig=tsconfig.webview.json && esbuild src/webview/commit/index.ts --bundle --outfile=out/webview/commit.js --format=iife --platform=browser --tsconfig=tsconfig.webview.json && esbuild src/webview/log/index.ts --bundle --outfile=out/webview/log.js --format=iife --platform=browser --tsconfig=tsconfig.webview.json && esbuild src/webview/rebase/index.ts --bundle --outfile=out/webview/rebase.js --format=iife --platform=browser --tsconfig=tsconfig.webview.json && esbuild src/webview/conflict/index.ts --bundle --outfile=out/webview/conflict.js --format=iife --platform=browser --tsconfig=tsconfig.webview.json",
        "watch:ext": "tsc -watch -p ./",
        "watch:webview": "esbuild src/webview/modal/index.ts --bundle --outfile=out/webview/modal.js --format=iife --platform=browser --watch & esbuild src/webview/diff/index.ts --bundle --outfile=out/webview/diff.js --format=iife --platform=browser --watch & esbuild src/webview/commit/index.ts --bundle --outfile=out/webview/commit.js --format=iife --platform=browser --watch & esbuild src/webview/log/index.ts --bundle --outfile=out/webview/log.js --format=iife --platform=browser --watch & esbuild src/webview/rebase/index.ts --bundle --outfile=out/webview/rebase.js --format=iife --platform=browser --watch & esbuild src/webview/conflict/index.ts --bundle --outfile=out/webview/conflict.js --format=iife --platform=browser --watch",
        "pretest": "pnpm run compile && pnpm run lint",
        "lint": "eslint src --ignore-pattern src/webview",
        "format": "prettier --write **/*.{ts,js,json,md,css,yml,yaml}",
        "test": "vscode-test",
        "prepare": "husky"
    },
    "lint-staged": {
        "**/*.{ts,js}": [
            "prettier --write",
            "eslint --fix"
        ],
        "**/*.{json,md,css,yml,yaml}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "@haerphi/vscode-git-api-types": "^1.0.2",
        "lit": "^3.3.3"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "~22.19.21",
        "@types/vscode": "^1.125.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "esbuild": "^0.28.1",
        "eslint": "^9.39.3",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "prettier": "^3.8.4",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    }
}
