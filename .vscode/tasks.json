// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "compile",
            "type": "npm",
            "script": "compile",
            "problemMatcher": "$tsc",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "type": "npm",
            "script": "watch:ext",
            "label": "watch:ext",
            "problemMatcher": "$tsc-watch",
            "isBackground": true,
            "presentation": {
                "reveal": "never"
            }
        },
        {
            "type": "npm",
            "script": "watch:webview",
            "label": "watch:webview",
            "problemMatcher": [],
            "isBackground": true,
            "presentation": {
                "reveal": "never"
            }
        },
        {
            "label": "watch",
            "dependsOn": ["watch:ext", "watch:webview"],
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "reveal": "never"
            }
        }
    ]
}
